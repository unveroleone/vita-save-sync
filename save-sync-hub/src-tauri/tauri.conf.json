{
  "$schema": "https://raw.githubusercontent.com/nicedoc/schemas/main/tauri-conf-v2.json",
  "productName": "Save Sync Hub",
  "version": "0.1.0",
  "identifier": "com.unveroleone.save-sync-hub",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Save Sync Hub",
        "width": 900,
        "height": 560,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ]
  }
}
